# ─── Database ──────────────────────────────────────────────────────────
# Docker (default) — รัน `docker compose up -d` ที่ project root ก่อน
DATABASE_URL=postgresql://mt5bot:devpassword123@localhost:5432/mt5bot

# Alternative: SQLite (เหมาะ prototype สั้นๆ)
# DATABASE_URL=sqlite:///./mt5bot.db

# ─── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-random-string-min-32-chars
APP_ENV=development

# Super user designation — comma-separated emails
# ตอน login ถ้า email ตรง → auto-set is_admin=True (lazy promote)
# ลบ email ออกจาก list จะไม่ revoke admin ที่ promote ไปแล้ว — ต้อง manual UPDATE
SUPER_USER_EMAILS=test@test.com

# ─── Encryption ────────────────────────────────────────────────────────
# Generate ครั้งแรก:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── VPS Bot (จะใช้ภายหลัง) ─────────────────────────────────────────────
VPS_API_URL=http://127.0.0.1:8001
VPS_API_KEY=
